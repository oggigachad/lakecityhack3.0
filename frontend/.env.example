# ─── VeriSignal Frontend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in before running npm run dev

# Backend API base URL
VITE_API_URL=http://localhost:8000

# WebSocket base URL
VITE_WS_URL=ws://localhost:8000

# Google Maps API Key — get from console.cloud.google.com
VITE_MAPS_KEY=YOUR_GOOGLE_MAPS_API_KEY
