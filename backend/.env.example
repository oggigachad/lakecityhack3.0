# ─── VeriSignal Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values before running.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/verisignal?retryWrites=true&w=majority

# Database name
DB_NAME=verisignal

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Google OAuth 2.0 — create at console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# VeriAI model path (relative to project root)
VERI_AI_MODEL_PATH=../models/fine_tuned_roberta

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Backend URL (used by scraper to trigger WS broadcast)
BACKEND_URL=http://localhost:8000
